# ============================================================
# Invoixe — environment template. Copy to .env and fill in.
# Do NOT put real secrets here; this file is committed.
#
# This repo-root .env is the SINGLE source of truth for both sides:
# the API loads it via dotenv, and client/web/next.config.mjs loads it before
# Next inlines NEXT_PUBLIC_*. Do not add client/web/.env or .env.local — those
# shadow this file silently and drift.
# ============================================================

# --- Ports ---
API_PORT="5000"   # NestJS API. Web runs on 3000 (see client/web dev script).

# --- Logging ---
# The API prints a startup report (env, database, auth, cors) and otherwise only
# errors and warnings. Set API_VERBOSE=true to restore Nest's full logs — a line
# per module and per mapped route (79 of them), useful when debugging routing.
# API_VERBOSE="true"

# --- CORS ---
# Comma-separated list of browser origins allowed to call the API.
# Defaults to http://localhost:3000 when unset.
FRONTEND_ORIGINS="http://localhost:3000"

# --- Prisma / Postgres (Supabase) ---
# Runtime uses the TRANSACTION pooler (port 6543, ?pgbouncer=true); migrations use
# the SESSION pooler (port 5432). See .env for the working local config.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# --- Supabase project ---
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY="<anon-key>"

# --- Server-only secrets (never prefix NEXT_PUBLIC) ---
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
SUPABASE_JWT_SECRET="<jwt-secret>"

# --- Public (browser-safe; inlined into the browser bundle at build time) ---
# NOT secrets: anyone loading the site can read these. RLS is what protects the
# data — re-run `npm run db:rls` after every schema change.
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"

# --- GSTIN lookup (Add Party auto-fill) ---
# Provider key for resolving registered-taxpayer details from a GSTIN. The
# default endpoint follows Appyflow's verifyGST API (https://appyflow.in/gst-api);
# set GST_API_URL to point at a compatible provider. When GST_API_KEY is unset,
# the party form still auto-fills the state from the GSTIN prefix (offline).
GST_API_KEY=""
# GST_API_URL="https://appyflow.in/api/verifyGST"

# --- OTP delivery ---
# No SMS/SMTP provider is wired up yet. Set OTP_DEV_MODE=true for LOCAL work to
# have /api/auth/otp/send return the code in its response (and log it) so the
# flow is testable. Never enable this outside local dev: anyone could request a
# code for someone else's phone/email and read it back. It is ignored when
# NODE_ENV=production.
# OTP_DEV_MODE="true"
