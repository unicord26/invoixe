{
  "extends": "@invoixe/config/tsconfig.base",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "types": ["node"],
    // tsc only type-checks here; build.mjs (esbuild + SWC) emits dist/.
    "noEmit": true,
    // NestJS DI resolves constructor params from design:paramtypes metadata,
    // which only the decorator transforms below emit.
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src/**/*.ts"]
}
